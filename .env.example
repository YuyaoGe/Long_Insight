# API Configuration
# Set one of the following API keys:
OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: custom API base URL (for proxies or compatible services)
# API_BASE_URL=https://api.openai.com/v1

# Analysis settings
# LLM_MODEL=claude-sonnet-4
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096
# MAX_TURNS_TO_ANALYZE=100
# DEBUG=false
